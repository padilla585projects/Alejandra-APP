# Wrangler local dev cache (R2 emulation, D1 local, etc.)
.wrangler/

# R2 local emulation data (fotos subidas en wrangler dev)
e1/
e2/
e3/
e4/
e5/

# Manifiesto OTA de la app Android (copia local suelta).
# La fuente de verdad la sirve el worker desde R2 (env.FILES.get('ota/version.json'),
# endpoint /version). Trackear la copia del repo solo crea una segunda verdad que
# puede quedar desincronizada — por eso se ignora.
ota/

# Node
node_modules/

# OS
.DS_Store
Thumbs.db
node_modules/
package.json
package-lock.json
# Excepción: alejandra-agente sí necesita package.json/lockfile trackeados
# (devDependency vitest para lib.test.js, instalado por el workflow de deploy
# antes de desplegar — ver .github/workflows/deploy-alejandra-agente.yml).
!alejandra-agente/package.json
!alejandra-agente/package-lock.json

# Claves y secretos — NUNCA commitear
CLAVES.txt
NUEVA_CUENTA.txt
*.env
.env*
backups/
