# ============================================================
# ALEJANDRA APP — Variables de entorno / Cloudflare Secrets
# ============================================================
# Este archivo documenta todos los secrets necesarios.
# NUNCA commitear los valores reales. Configurar en:
#   → Cloudflare Dashboard → Workers & Pages → alejandra-app-api → Settings → Variables
#   → O via CLI: npx wrangler secret put <NOMBRE>
#
# Los valores reales están en NUEVA_CUENTA.txt (local, en .gitignore).
# ============================================================

# ── Autenticación interna ────────────────────────────────────
ADMIN_CODE=<codigo-superadmin-interno>

# ── IA — Anthropic (Alejandra / Claude) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── IA — Google (Gemini, para scan de partes) ───────────────
GEMINI_API_KEY=AIza...

# ── IA — Tavily (búsqueda web para el agente) ───────────────
TAVILY_API_KEY=tvly-...

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<token-botfather>
TELEGRAM_CHAT_ID=<chat-id-principal>
DEV_CHAT_ID=<chat-id-desarrollador>
TELEGRAM_WEBHOOK_SECRET=<secret-webhook>

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Google OAuth (login con Google) ─────────────────────────
GOOGLE_OAUTH_CLIENT_ID=<client-id>.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# ── Google Sheets (sync automático) ─────────────────────────
GOOGLE_SHEET_ID=<id-hoja-principal>
GOOGLE_PEDIDOS_SHEET_ID=<id-hoja-pedidos>
GOOGLE_CLIENT_EMAIL=<service-account>@<proyecto>.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# ── GitHub (para direct_fix y repo_read_file de Alejandra) ──
GITHUB_TOKEN=github_pat_...

# ── Web Push VAPID (notificaciones push) ────────────────────
VAPID_PUBLIC_KEY=<clave-publica-VAPID-base64url>
VAPID_PRIVATE_KEY=<clave-privada-VAPID-base64url>
# Generar par VAPID: npx web-push generate-vapid-keys

# ── Cloudflare Bindings (se configuran en wrangler.toml) ────
# DB = binding D1 → alejandra-db
# FILES = binding R2 → alejandra-app-files
